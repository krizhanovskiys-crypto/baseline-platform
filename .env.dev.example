# Development environment template.
#
# Copy this file to `.env.dev` and fill in real values:
#   cp .env.dev.example .env.dev
#
# Loaded automatically when the process is started with ENV=development
# (see backend/app/core/config.py — _resolve_env_file()). Never commit the
# filled-in `.env.dev` file; it's gitignored already.

# ── Telegram ──────────────────────────────────────────────────────────────────
# MUST be a separate bot (e.g. talk to @BotFather, create "MyBot Dev").
# Never reuse the production bot token here.
BOT_TOKEN=your_development_bot_token_here

# ── Database ───────────────────────────────────────────────────────────────────
# A separate file from production — safe to wipe/reset during development.
DATABASE_URL=sqlite+aiosqlite:///./baseline-dev.db

# ── Developer ──────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs that can access /dev
DEVELOPER_IDS=

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG
