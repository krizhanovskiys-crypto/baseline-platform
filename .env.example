# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./baseline.db

# PostgreSQL (production) — uncomment and fill in
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/baseline

# ── Developer ──────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs that can access /dev
# DEVELOPER_IDS=123456789,987654321

# ── Admin Center ─────────────────────────────────────────────────────────────
# Required for Admin Center bootstrap.
# First Owner account(s), comma-separated Telegram IDs.
OWNER_IDS=

# Required for Admin Center authentication.
ADMIN_PIN=

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO
