# Production environment template.
#
# Copy this file to `.env.production` and fill in real values, OR keep
# using a plain `.env` on the server exactly as today — both work.
#   cp .env.production.example .env.production
#
# Loaded automatically when the process is started with ENV=production
# (see backend/app/core/config.py — _resolve_env_file()). Never commit the
# filled-in `.env.production` file; it's gitignored already.

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_production_bot_token_here

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./baseline.db
# PostgreSQL — uncomment and fill in if/when production migrates off SQLite
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/baseline

# ── Developer ──────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs that can access /dev
DEVELOPER_IDS=

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
